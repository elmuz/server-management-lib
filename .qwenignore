# Qwen Code ignore file
# Files matching these patterns will be excluded from context scanning

# =============================================================================
# Python / Virtual Environments
# =============================================================================
.venv/
venv/
env/
.venv
venv
env/
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
.eggs/

# =============================================================================
# Environment & Secrets (IMPORTANT: Prevents accidental exposure)
# =============================================================================
.env
.env.local
.env.*.local
.env.development
.env.test
.env.production
*.pem
*.key
secrets.json
credentials.json

# =============================================================================
# Build & Distribution Artifacts
# =============================================================================
dist/
build/
*.so
*.dylib
*.dll
*.egg
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/

# =============================================================================
# IDE & Editor Files
# =============================================================================
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# =============================================================================
# Logs & Temporary Files
# =============================================================================
*.log
logs/
*.tmp
*.bak
*.temp
tmp/
temp/

# =============================================================================
# Large Data Files (Not useful for code context)
# =============================================================================
*.csv
*.xlsx
*.xls
*.pdf
*.zip
*.tar.gz
*.rar
*.7z
*.dat

# =============================================================================
# Node.js (if applicable)
# =============================================================================
node_modules/
npm-debug.log
yarn-error.log

# =============================================================================
# Qwen Internal (Don't scan Qwen's own files)
# =============================================================================
.qwen/tmp/
